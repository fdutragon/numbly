# Este arquivo seria um ícone PNG de 192x192 pixels
# Como não posso criar imagens binárias, aqui está um placeholder
# Você deve criar os ícones PWA usando as dimensões especificadas no manifest.json

# Pode usar ferramentas como:
# - https://realfavicongenerator.net/
# - https://www.pwabuilder.com/imageGenerator
# - ou qualquer editor de imagem

# Dimensões necessárias:
# - 72x72, 96x96, 128x128, 144x144
# - 152x152, 192x192, 384x384, 512x512

# Exemplo de SVG base para conversão:
<?xml version="1.0" encoding="UTF-8"?>
<svg viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg">
  <rect width="192" height="192" rx="24" fill="#3b82f6"/>
  <text x="96" y="110" font-family="Arial" font-size="100" font-weight="bold" text-anchor="middle" fill="white">DA</text>
  <circle cx="96" cy="60" r="20" fill="white"/>
</svg>
