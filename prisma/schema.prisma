// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InviteStatus {
  PENDING     // Convite enviado, aguardando cadastro
  ACCEPTED    // Pessoa se cadastrou via convite
  EXPIRED     // Convite expirou
  BLOCKED     // Convite foi bloqueado
}

enum RelationshipType {
  FRIEND      // Amigo
  FAMILY      // Família
  ROMANTIC    // Parceiro romântico
  BUSINESS    // Sócio/Negócios
  CRUSH       // Paquera/Interesse
  PET         // Pet (sim, vai ter isso!)
  OTHER       // Outro
}

enum CompatibilityStatus {
  WAITING     // Aguardando a outra pessoa aceitar
  REVEALED    // Mapa revelado para ambos
  BLOCKED     // Bloqueado por um dos lados
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

model User {
  id             String          @id @default(uuid())
  email          String?         @unique // Agora opcional para login via push
  name           String?
  birthDate      DateTime        // Mudado para DateTime
  isPremium      Boolean         @default(false)
  credits        Int             @default(5)
  profileImage   String?
  bio            String?
  numerologyData Json
  role           UserRole        @default(USER)
  sentFriendRequests     Friendship[]    @relation("SentFriendRequests")
  receivedFriendRequests Friendship[]    @relation("ReceivedFriendRequests")
  compatibility  Compatibility[] @relation("UserCompatibility")
  
  // Sistema de convites virais
  sentInvites            Invite[]        @relation("SentInvites")
  receivedInvites        Invite[]        @relation("ReceivedInvites")
  
  // Mapas de compatibilidade
  initiatedMaps          CompatibilityMap[] @relation("InitiatedMaps")
  receivedMaps           CompatibilityMap[] @relation("ReceivedMaps")
  
  // Sessões do oráculo combinado
  oracleSessions         OracleSession[] @relation("UserOracleSessions")
  
  posts          Post[]
  comments       Comment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  hasSeenIntro   Boolean         @default(false)
  
  // Relação com dispositivos para login via push
  devices        UserDevice[]    @relation("UserDevices")
  subscriptions  UserSubscription[]
  pushSubscriptions PushSubscription[] @relation("UserPushSubscriptions")
  
  // Blog místico - novas relações
  aiComments      AIComment[]
  journalEntries  JournalEntry[]
  userChallenges  UserChallenge[]
  oracleMessages  OracleMessage[]
  userBadges      UserBadge[]
  emotionalCycles EmotionalCycle[]
  futureLetters   FutureLetter[]
  recommendations RecommendationEngine[]
}

model UserDevice {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)
  deviceId    String   @unique
  deviceName  String?
  platform    String?
  userAgent   String?
  lastSeen    DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Friendship {
  id         String           @id @default(uuid())
  sender     User             @relation("SentFriendRequests", fields: [senderId], references: [id])
  senderId   String
  receiver   User             @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([senderId, receiverId])
}

model Post {
  id        String    @id @default(uuid())
  content   String
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  post      Post     @relation(fields: [postId], references: [id])
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Compatibility {
  id            String   @id @default(uuid())
  user          User     @relation("UserCompatibility", fields: [userId], references: [id])
  userId        String
  target_email  String?
  target_name   String
  target_date   String
  numerologyData Json
  score         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, target_name, target_date])
}

model Report {
  id         String   @id @default(uuid())
  userId     String
  type       String   // Tipo de análise (lifePath, destiny, etc.)
  number     String   // Número analisado
  content    String   // Conteúdo do relatório gerado
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, type])
}

model PushSubscription {
  id              String    @id @default(uuid())
  endpoint        String?   @unique // Endpoint da subscription push
  deviceId        String    @unique
  subscription    String    // JSON da subscription
  installedAt     DateTime  @default(now())
  userAgent       String?
  platform        String?
  isActive        Boolean   @default(true)
  hasPurchased    Boolean   @default(false)
  pushSent        Boolean   @default(false)
  pushSentAt      DateTime?
  purchasedAt     DateTime?
  purchaseId      String?
  purchaseAmount  Float?
  lastUpdated     DateTime  @updatedAt
  createdAt       DateTime  @default(now())
  userId          String?   // Relacionamento com User
  user            User?     @relation(fields: [userId], references: [id])
}

model MagicToken {
  id        String    @id @default(uuid())
  token     String    @unique
  email     String
  used      Boolean   @default(false)
  expiresAt DateTime? // Agora pode ser null para tokens permanentes
  createdAt DateTime  @default(now())
  usedAt    DateTime?
}

model SubscriptionPlanDetails {
  id                  String            @id @default(uuid())
  plan                SubscriptionPlan  @unique
  name                String
  description         String?
  price               Float             @default(0)
  currency            String            @default("BRL")
  billingCycle        String            @default("MONTHLY") // MONTHLY, QUARTERLY, YEARLY
  features            String[]          @default([])
  maxUsers            Int?
  maxAccounts         Int?
  maxTransactions     Int?
  maxGoals            Int?
  hasAdvancedReports  Boolean           @default(false)
  hasAIInsights       Boolean           @default(false)
  hasPrioritySupport  Boolean           @default(false)
  hasMultiCurrency    Boolean           @default(false)
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("subscription_plan_details")
}

model UserSubscription {
  id                String            @id @default(cuid())
  userId            String
  plan              SubscriptionPlan   @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  startDate         DateTime           @default(now())
  endDate           DateTime?
  renewalDate       DateTime?
  isActive          Boolean            @default(true)
  paymentMethod     String?
  lastPaymentDate   DateTime?
  nextPaymentDate   DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_subscriptions")
}

// npx prisma migrate dev --name nome-da-migracao

// ===== SISTEMA DE CONVITES VIRAIS =====

model Invite {
  id              String           @id @default(uuid())
  code            String           @unique // Código único do convite (6-8 chars)
  
  // Quem enviou o convite
  sender          User             @relation("SentInvites", fields: [senderId], references: [id])
  senderId        String
  
  // Para quem foi enviado (opcional se enviar por link)
  receiver        User?            @relation("ReceivedInvites", fields: [receiverId], references: [id])
  receiverId      String?
  
  // Dados da pessoa convidada (antes de se cadastrar)
  invitedName     String           // Nome da pessoa convidada
  invitedEmail    String?          // Email (opcional)
  invitedPhone    String?          // Telefone (opcional)
  
  // Tipo de relacionamento pretendido
  relationshipType RelationshipType @default(FRIEND)
  
  // Status e tracking
  status          InviteStatus     @default(PENDING)
  clicks          Int              @default(0)
  lastClickedAt   DateTime?
  
  // Mensagem personalizada do convite
  customMessage   String?
  
  // Metadata
  expiresAt       DateTime?        // Convites podem expirar
  acceptedAt      DateTime?        // Quando foi aceito
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Relação com mapa de compatibilidade
  compatibilityMap CompatibilityMap?
  
  @@index([code])
  @@index([senderId])
  @@index([status])
}

// ===== MAPAS DE COMPATIBILIDADE =====

model CompatibilityMap {
  id              String              @id @default(uuid())
  
  // Relacionamento com convite
  invite          Invite              @relation(fields: [inviteId], references: [id])
  inviteId        String              @unique
  
  // Usuários envolvidos
  initiator       User                @relation("InitiatedMaps", fields: [initiatorId], references: [id])
  initiatorId     String
  
  partner         User?               @relation("ReceivedMaps", fields: [partnerId], references: [id])
  partnerId       String?
  
  // Tipo de relacionamento
  
  // Status do mapa
  status          CompatibilityStatus @default(WAITING)
  
  // Dados numerológicos dos envolvidos
  initiatorData   Json                // Mapa numerológico completo do iniciador
  partnerData     Json?               // Mapa numerológico do parceiro (só após aceite)
  
  // Análise de compatibilidade (só revelada após aceite mútuo)
  compatibilityScore Float?           // Score de 0 a 100
  compatibilityAnalysis Json?         // Análise detalhada da compatibilidade
  strengthsAndChallenges Json?        // Pontos fortes e desafios do relacionamento
  
  // Relatório personalizado
  customReport    String?             // Relatório IA gerado para esta dupla específica
  reportGenerated Boolean             @default(false)
  
  // Oráculo combinado
  oracleUnlocked  Boolean             @default(false)
  oracleUsed      Boolean             @default(false)
  oracleSessions  OracleSession[]     // Sessões do oráculo para este mapa
  
  // Tracking de engajamento
  timesViewed     Int                 @default(0)
  lastViewedAt    DateTime?
  sharedTimes     Int                 @default(0)
  
  // Metadata
  revealedAt      DateTime?           // Quando o mapa foi revelado
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([initiatorId])
  @@index([partnerId])
  @@index([status])
}

// ===== ORÁCULO COMBINADO =====

model OracleSession {
  id              String           @id @default(uuid())
  
  // Mapa de compatibilidade relacionado
  compatibilityMap CompatibilityMap @relation(fields: [mapId], references: [id])
  mapId           String
  
  // Participantes
  users           User[]           @relation("UserOracleSessions")
  
  // Sessão do oráculo
  question        String           // Pergunta feita em conjunto
  answer          String?          // Resposta mística gerada
  
  // Condições para ativação
  bothUsersActive Boolean          @default(false) // Ambos precisam estar online
  questionAskedAt DateTime?        // Quando a pergunta foi feita
  answeredAt      DateTime?        // Quando foi respondida
  
  // Metadata mística
  cosmicAlignment String?          // Alinhamento cósmico no momento
  lunarPhase      String?          // Fase da lua
  numerologyFocus String?          // Foco numerológico da sessão
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([mapId])
}

// ===== BLOG MÍSTICO =====

enum BlogPostType {
  DAILY_MEDITATION   // Meditação diária
  ARTICLE           // Artigo espiritual
  ORACLE_MESSAGE    // Mensagem do oráculo
  RITUAL_GUIDE      // Guia de ritual
  NUMEROLOGY_INSIGHT // Insight numerológico
}

enum MoodType {
  PEACEFUL      // 😌 Tranquilo
  ANXIOUS       // 😰 Ansioso
  GRATEFUL      // 🙏 Grato
  REFLECTIVE    // 🤔 Reflexivo
  ENERGETIC     // ⚡ Energético
  MELANCHOLIC   // 😔 Melancólico
  INSPIRED      // ✨ Inspirado
  CONFUSED      // 😵 Confuso
  BALANCED      // ⚖️ Equilibrado
}

enum ChallengeType {
  GRATITUDE     // Gratidão diária
  MEDITATION    // Meditação
  JOURNALING    // Escrita reflexiva
  SILENCE       // Momentos de silêncio
  KINDNESS      // Atos de bondade
  PRESENCE      // Presença consciente
  FORGIVENESS   // Perdão
}

enum BadgeType {
  GUARDIAN_CONSTANCY    // Guardião da Constância
  SOUL_SCRIBE          // Escriba da Alma
  SILENCE_DISCIPLE     // Discípulo do Silêncio
  ORACLE_SEEKER        // Buscador do Oráculo
  RITUAL_MASTER        // Mestre dos Rituais
  CYCLE_READER         // Leitor de Ciclos
  FUTURE_KEEPER        // Guardião do Futuro
}

model BlogPost {
  id              String        @id @default(uuid())
  title           String
  content         String        // Conteúdo principal
  excerpt         String?       // Resumo
  type            BlogPostType  @default(ARTICLE)
  
  // Metadata espiritual
  personalDay     Int?          // Para qual dia pessoal é mais relevante
  lunarPhase      String?       // Fase da lua
  numerologyFocus String?       // Foco numerológico
  cosmicEvent     String?       // Evento cósmico especial
  
  // Meditação guiada (se aplicável)
  meditationAudio String?       // URL do áudio
  meditationDuration Int?       // Duração em segundos
  meditationScript String?      // Script da meditação
  
  // Tags e categorias
  tags            String[]      @default([])
  category        String?
  
  // Engajamento
  views           Int           @default(0)
  likes           Int           @default(0)
  
  // Comentários IA
  aiComments      AIComment[]
  
  // Entradas do diário relacionadas
  journalEntries  JournalEntry[]
  
  // Publicação
  isPublished     Boolean       @default(true)
  publishedAt     DateTime      @default(now())
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([type])
  @@index([personalDay])
  @@index([publishedAt])
}

model AIComment {
  id          String      @id @default(uuid())
  
  // Post relacionado
  blogPost    BlogPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  
  // Usuário que fez o comentário
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  // Comentário do usuário
  userComment String      // "Me senti ansioso hoje"
  
  // Resposta da IA
  aiResponse  String      // Resposta poética e simbólica
  
  // Contexto usado pela IA
  userMood    MoodType?   // Humor detectado
  personalDay Int?        // Dia pessoal do usuário
  cosmicContext String?   // Contexto cósmico do momento
  
  createdAt   DateTime    @default(now())
  
  @@index([postId])
  @@index([userId])
}

model JournalEntry {
  id              String      @id @default(uuid())
  
  // Usuário
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  
  // Conteúdo
  content         String      // Texto reflexivo
  mood            MoodType?   // Humor do momento
  
  // Contexto
  personalDay     Int?        // Dia pessoal
  blogPost        BlogPost?   @relation(fields: [blogPostId], references: [id])
  blogPostId      String?     // Post que inspirou a entrada
  
  // Metadata
  isPrivate       Boolean     @default(true)
  
  // Insights da IA
  aiInsights      String?     // Padrões detectados pela IA
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([userId])
  @@index([personalDay])
  @@index([createdAt])
}

model WeeklyChallenge {
  id              String          @id @default(uuid())
  title           String
  description     String
  type            ChallengeType
  
  // Duração
  startDate       DateTime
  endDate         DateTime
  
  // Recompensas
  badgeReward     BadgeType?
  creditsReward   Int             @default(0)
  
  // Engajamento
  participants    UserChallenge[]
  
  // Tema espiritual
  spiritualTheme  String?         // Tema da semana (ex: "Gratidão", "Perdão")
  personalDayFocus Int?           // Foco em dias pessoais específicos
  
  isActive        Boolean         @default(true)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([startDate, endDate])
  @@index([isActive])
}

model UserChallenge {
  id              String          @id @default(uuid())
  
  // Relacionamentos
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  challenge       WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  challengeId     String
  
  // Progresso
  progress        Int             @default(0) // Dias completados
  isCompleted     Boolean         @default(false)
  completedAt     DateTime?
  
  // Tracking diário
  dailyProgress   Json            @default("{}") // {"day1": true, "day2": false, ...}
  
  // Recompensas recebidas
  badgeEarned     Boolean         @default(false)
  creditsEarned   Int             @default(0)
  
  joinedAt        DateTime        @default(now())
  
  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
}

model OracleMessage {
  id              String      @id @default(uuid())
  
  // Usuário que recebeu
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  
  // Contexto da mensagem
  question        String?     // Pergunta do usuário (opcional)
  message         String      // Mensagem do oráculo
  
  // Contexto espiritual
  personalDay     Int?        // Dia pessoal
  mood            MoodType?   // Humor do momento
  lunarPhase      String?     // Fase da lua
  cosmicAlignment String?     // Alinhamento cósmico
  
  // Tipo de oráculo
  type            String      @default("CONTEXTUAL") // CONTEXTUAL, DAILY, FUTURE_LETTER
  
  // Lida ou não
  isRead          Boolean     @default(false)
  readAt          DateTime?
  
  createdAt       DateTime    @default(now())
  
  @@index([userId])
  @@index([personalDay])
  @@index([type])
}

model UserBadge {
  id          String      @id @default(uuid())
  
  // Usuário
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  // Badge
  badge       BadgeType
  
  // Contexto
  earnedFor   String?     // Descrição de como foi conquistado
  challenge   String?     // Desafio relacionado
  
  earnedAt    DateTime    @default(now())
  
  @@unique([userId, badge])
  @@index([userId])
}

model EmotionalCycle {
  id              String      @id @default(uuid())
  
  // Usuário
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  
  // Dados do ciclo
  personalDay     Int         // Dia pessoal
  mood            MoodType    // Humor reportado
  energy          Int         // Nível de energia (1-10)
  activity        String?     // Atividade realizada
  
  // Contexto
  blogPostRead    String?     // ID do post lido
  meditationDone  Boolean     @default(false)
  journalWritten  Boolean     @default(false)
  
  // Insights da IA
  aiPattern       String?     // Padrão detectado
  aiRecommendation String?    // Recomendação da IA
  
  recordedAt      DateTime    @default(now())
  
  @@index([userId])
  @@index([personalDay])
  @@index([recordedAt])
}

model FutureLetter {
  id              String      @id @default(uuid())
  
  // Usuário
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  
  // Conteúdo
  message         String      // Mensagem simbólica
  
  // Contexto de criação
  createdDuringStreak Int     // Sequência de dias que desbloqueou
  personalDayContext  Int?    // Dia pessoal do momento
  
  // Entrega
  deliverAt       DateTime    // Quando deve ser entregue
  isDelivered     Boolean     @default(false)
  deliveredAt     DateTime?
  
  // Engajamento
  isRead          Boolean     @default(false)
  readAt          DateTime?
  isSaved         Boolean     @default(false)
  isShared        Boolean     @default(false)
  
  createdAt       DateTime    @default(now())
  
  @@index([userId])
  @@index([deliverAt])
  @@index([isDelivered])
}

model RecommendationEngine {
  id              String      @id @default(uuid())
  
  // Usuário
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  
  // Tipo de recomendação
  type            String      // "POST_AFTER_MEDITATION", "MEDITATION_AFTER_POST", etc.
  
  // Contexto
  sourceId        String      // ID do post/meditação que gerou a recomendação
  recommendedId   String      // ID do conteúdo recomendado
  
  // Relevância
  score           Float       // Score de relevância (0-1)
  personalDayMatch Boolean    @default(false)
  moodMatch       Boolean     @default(false)
  
  // Engajamento
  wasClicked      Boolean     @default(false)
  clickedAt       DateTime?
  
  createdAt       DateTime    @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([score])
}

// Relacionamentos adicionais para User já incluídos no modelo User principal acima
