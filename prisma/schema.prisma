// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InviteStatus {
  PENDING     // Convite enviado, aguardando cadastro
  ACCEPTED    // Pessoa se cadastrou via convite
  EXPIRED     // Convite expirou
  BLOCKED     // Convite foi bloqueado
}

enum RelationshipType {
  FRIEND      // Amigo
  FAMILY      // Família
  ROMANTIC    // Parceiro romântico
  BUSINESS    // Sócio/Negócios
  CRUSH       // Paquera/Interesse
  PET         // Pet (sim, vai ter isso!)
  OTHER       // Outro
}

enum CompatibilityStatus {
  WAITING     // Aguardando a outra pessoa aceitar
  REVEALED    // Mapa revelado para ambos
  BLOCKED     // Bloqueado por um dos lados
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

model User {
  id             String          @id @default(uuid())
  email          String?         @unique // Agora opcional para login via push
  name           String?
  birthDate      DateTime        // Mudado para DateTime
  isPremium      Boolean         @default(false)
  credits        Int             @default(5)
  profileImage   String?
  bio            String?
  numerologyData Json
  role           UserRole        @default(USER)
  sentFriendRequests     Friendship[]    @relation("SentFriendRequests")
  receivedFriendRequests Friendship[]    @relation("ReceivedFriendRequests")
  compatibility  Compatibility[] @relation("UserCompatibility")
  
  // Sistema de convites virais
  sentInvites            Invite[]        @relation("SentInvites")
  receivedInvites        Invite[]        @relation("ReceivedInvites")
  
  // Mapas de compatibilidade
  initiatedMaps          CompatibilityMap[] @relation("InitiatedMaps")
  receivedMaps           CompatibilityMap[] @relation("ReceivedMaps")
  
  // Sessões do oráculo combinado
  oracleSessions         OracleSession[] @relation("UserOracleSessions")
  
  posts          Post[]
  comments       Comment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  hasSeenIntro   Boolean         @default(false)
  
  // Relação com dispositivos para login via push
  devices        UserDevice[]    @relation("UserDevices")
  subscriptions  UserSubscription[]
}

model UserDevice {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)
  deviceId    String   @unique
  deviceName  String?
  platform    String?
  userAgent   String?
  lastSeen    DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Friendship {
  id         String           @id @default(uuid())
  sender     User             @relation("SentFriendRequests", fields: [senderId], references: [id])
  senderId   String
  receiver   User             @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([senderId, receiverId])
}

model Post {
  id        String    @id @default(uuid())
  content   String
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  post      Post     @relation(fields: [postId], references: [id])
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Compatibility {
  id            String   @id @default(uuid())
  user          User     @relation("UserCompatibility", fields: [userId], references: [id])
  userId        String
  target_email  String?
  target_name   String
  target_date   String
  numerologyData Json
  score         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, target_name, target_date])
}

model Report {
  id         String   @id @default(uuid())
  userId     String
  type       String   // Tipo de análise (lifePath, destiny, etc.)
  number     String   // Número analisado
  content    String   // Conteúdo do relatório gerado
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, type])
}

model PushSubscription {
  id              String    @id @default(uuid())
  endpoint        String?   @unique // Endpoint da subscription push
  deviceId        String    @unique
  subscription    String    // JSON da subscription
  installedAt     DateTime  @default(now())
  userAgent       String?
  platform        String?
  isActive        Boolean   @default(true)
  hasPurchased    Boolean   @default(false)
  pushSent        Boolean   @default(false)
  pushSentAt      DateTime?
  purchasedAt     DateTime?
  purchaseId      String?
  purchaseAmount  Float?
  lastUpdated     DateTime  @updatedAt
  createdAt       DateTime  @default(now())
}

model MagicToken {
  id        String    @id @default(uuid())
  token     String    @unique
  email     String
  used      Boolean   @default(false)
  expiresAt DateTime? // Agora pode ser null para tokens permanentes
  createdAt DateTime  @default(now())
  usedAt    DateTime?
}

model SubscriptionPlanDetails {
  id                  String            @id @default(uuid())
  plan                SubscriptionPlan  @unique
  name                String
  description         String?
  price               Float             @default(0)
  currency            String            @default("BRL")
  billingCycle        String            @default("MONTHLY") // MONTHLY, QUARTERLY, YEARLY
  features            String[]          @default([])
  maxUsers            Int?
  maxAccounts         Int?
  maxTransactions     Int?
  maxGoals            Int?
  hasAdvancedReports  Boolean           @default(false)
  hasAIInsights       Boolean           @default(false)
  hasPrioritySupport  Boolean           @default(false)
  hasMultiCurrency    Boolean           @default(false)
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("subscription_plan_details")
}

model UserSubscription {
  id                String            @id @default(cuid())
  userId            String
  plan              SubscriptionPlan   @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  startDate         DateTime           @default(now())
  endDate           DateTime?
  renewalDate       DateTime?
  isActive          Boolean            @default(true)
  paymentMethod     String?
  lastPaymentDate   DateTime?
  nextPaymentDate   DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_subscriptions")
}

// npx prisma migrate dev --name nome-da-migracao

// ===== SISTEMA DE CONVITES VIRAIS =====

model Invite {
  id              String           @id @default(uuid())
  code            String           @unique // Código único do convite (6-8 chars)
  
  // Quem enviou o convite
  sender          User             @relation("SentInvites", fields: [senderId], references: [id])
  senderId        String
  
  // Para quem foi enviado (opcional se enviar por link)
  receiver        User?            @relation("ReceivedInvites", fields: [receiverId], references: [id])
  receiverId      String?
  
  // Dados da pessoa convidada (antes de se cadastrar)
  invitedName     String           // Nome da pessoa convidada
  invitedEmail    String?          // Email (opcional)
  invitedPhone    String?          // Telefone (opcional)
  
  // Tipo de relacionamento pretendido
  relationshipType RelationshipType @default(FRIEND)
  
  // Status e tracking
  status          InviteStatus     @default(PENDING)
  clicks          Int              @default(0)
  lastClickedAt   DateTime?
  
  // Mensagem personalizada do convite
  customMessage   String?
  
  // Metadata
  expiresAt       DateTime?        // Convites podem expirar
  acceptedAt      DateTime?        // Quando foi aceito
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Relação com mapa de compatibilidade
  compatibilityMap CompatibilityMap?
  
  @@index([code])
  @@index([senderId])
  @@index([status])
}

// ===== MAPAS DE COMPATIBILIDADE =====

model CompatibilityMap {
  id              String              @id @default(uuid())
  
  // Relacionamento com convite
  invite          Invite              @relation(fields: [inviteId], references: [id])
  inviteId        String              @unique
  
  // Usuários envolvidos
  initiator       User                @relation("InitiatedMaps", fields: [initiatorId], references: [id])
  initiatorId     String
  
  partner         User?               @relation("ReceivedMaps", fields: [partnerId], references: [id])
  partnerId       String?
  
  // Tipo de relacionamento
  relationshipType RelationshipType   @default(FRIEND)
  
  // Status do mapa
  status          CompatibilityStatus @default(WAITING)
  
  // Dados numerológicos dos envolvidos
  initiatorData   Json                // Mapa numerológico completo do iniciador
  partnerData     Json?               // Mapa numerológico do parceiro (só após aceite)
  
  // Análise de compatibilidade (só revelada após aceite mútuo)
  compatibilityScore Float?           // Score de 0 a 100
  compatibilityAnalysis Json?         // Análise detalhada da compatibilidade
  strengthsAndChallenges Json?        // Pontos fortes e desafios do relacionamento
  
  // Relatório personalizado
  customReport    String?             // Relatório IA gerado para esta dupla específica
  reportGenerated Boolean             @default(false)
  
  // Oráculo combinado
  oracleUnlocked  Boolean             @default(false)
  oracleUsed      Boolean             @default(false)
  oracleSessions  OracleSession[]     // Sessões do oráculo para este mapa
  
  // Tracking de engajamento
  timesViewed     Int                 @default(0)
  lastViewedAt    DateTime?
  sharedTimes     Int                 @default(0)
  
  // Metadata
  revealedAt      DateTime?           // Quando o mapa foi revelado
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([initiatorId])
  @@index([partnerId])
  @@index([status])
}

// ===== ORÁCULO COMBINADO =====

model OracleSession {
  id              String           @id @default(uuid())
  
  // Mapa de compatibilidade relacionado
  compatibilityMap CompatibilityMap @relation(fields: [mapId], references: [id])
  mapId           String
  
  // Participantes
  users           User[]           @relation("UserOracleSessions")
  
  // Sessão do oráculo
  question        String           // Pergunta feita em conjunto
  answer          String?          // Resposta mística gerada
  
  // Condições para ativação
  bothUsersActive Boolean          @default(false) // Ambos precisam estar online
  questionAskedAt DateTime?        // Quando a pergunta foi feita
  answeredAt      DateTime?        // Quando foi respondida
  
  // Metadata mística
  cosmicAlignment String?          // Alinhamento cósmico no momento
  lunarPhase      String?          // Fase da lua
  numerologyFocus String?          // Foco numerológico da sessão
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([mapId])
}
